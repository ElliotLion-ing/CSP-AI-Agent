# ============================================
# CSP AI Agent MCP Server Configuration
# ============================================

# Environment
NODE_ENV=development

# Server Configuration
PORT=5090
LOG_LEVEL=info

# Transport Configuration
# Mode: stdio (local development) or sse (production remote)
TRANSPORT_MODE=stdio

# HTTP Server Configuration (for SSE transport)
HTTP_HOST=0.0.0.0
HTTP_PORT=3000

# Session Configuration (for SSE transport)
SESSION_TIMEOUT=3600

# CSP API Configuration
# Base URL should include the /csp/api prefix according to API Mapping spec
# Example: https://csp.example.com (API will append /csp/api/resources/*)
CSP_API_BASE_URL=https://csp.example.com

# CSP API Token (This is the JWT token issued by CSP system)
# Used for:
# 1. Validating user authentication via GET /csp/api/user/permissions
# 2. Authorization header for all CSP API calls
CSP_API_TOKEN=your_jwt_token_here

CSP_API_TIMEOUT=30000

# Git Configuration
# GIT_USER_NAME / GIT_USER_EMAIL: used as the commit author in git log.
#   Local dev:          your own account (e.g. Elliot Ding / elliot.ding@zoom.us)
#   Production server:  Git Service Account (e.g. CSP Agent / ai-agent@zoom.us)
#
# NOTE: GIT_REPO_URL / GIT_BRANCH / GIT_AUTH_TOKEN are NOT used.
#   Each repo's URL and branch is configured per-source in AI-Resources/ai-resources-config.json.
GIT_USER_NAME=CSP Agent
GIT_USER_EMAIL=agent@example.com

# Resource Storage
# Resources are installed into Cursor's standard directories automatically:
#   macOS/Linux : ~/.cursor/skills/  ~/.cursor/commands/  ~/.cursor/rules/  ~/.cursor/mcp-servers/
#   Windows     : %APPDATA%\Cursor\User\<type>\
# No configuration needed — paths are resolved at runtime by cursor-paths utility.

# Cache Configuration
ENABLE_CACHE=true
REDIS_URL=redis://localhost:6379
REDIS_TTL=900
CACHE_MAX_SIZE=100

# Database Configuration (Optional)
DATABASE_URL=postgresql://user:pass@localhost:5432/csp

# Monitoring Configuration (Optional)
ENABLE_METRICS=true
METRICS_PORT=9090
SENTRY_DSN=

# Log Configuration
LOG_DIR=../Logs
LOG_RETENTION_DAYS=7

# Graceful Shutdown Configuration
# Maximum time (in milliseconds) to wait for graceful shutdown before forcing exit
# Default: 30000 (30 seconds)
SHUTDOWN_TIMEOUT=30000
