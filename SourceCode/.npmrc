# Security Settings
# Prevent postinstall scripts from running automatically (recommended for CI/CD)
# ignore-scripts=true

# Audit settings
audit-level=high

# Package lock settings
package-lock=true

# Strict SSL
strict-ssl=true

# Save exact versions (prevent ^ and ~ in package.json)
save-exact=true

# Engine strict (enforce Node.js version requirements)
engine-strict=true
